{
  "manifest_version": 3,
  "name": "Security Question Autofill",
  "version": "1.0.0",
  "description": "Automatically fills security question answers on atlasauth.b2clogin.com",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://atlasauth.b2clogin.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://atlasauth.b2clogin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
